    {
      "Type": "concept",
      "ID": "wal",
      "Title": "Write-Ahead Log (WAL)",
      "Body": "Mutations are held in memory and appended to a WAL on Commit; not visible to other processes until committed.",
      "Meta": {
        "anchor": "committing-and-closing",
        "generated_at": "<scrubbed>",
        "heading": "Committing and closing",
