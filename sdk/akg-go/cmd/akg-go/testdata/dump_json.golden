    {
      "Type": "concept",
      "ID": "compaction",
      "Title": "Compaction",
      "Body": "Rewrites the file to contain only live records, discarding WAL history; caller-triggered, never automatic.",
      "Meta": {
        "anchor": "compaction",
        "generated_at": "<scrubbed>",
        "heading": "Compaction",
        "language": "go",
