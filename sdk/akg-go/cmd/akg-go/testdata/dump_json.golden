    {
      "Type": "concept",
      "ID": "single_writer",
      "Title": "Single-writer semantics",
      "Body": "Only one process should have a store open for writing at a time; concurrent access produces undefined behavior.",
      "Meta": {
        "anchor": "concurrency-and-single-writer-semantics",
        "generated_at": "<scrubbed>",
        "heading": "Concurrency and single-writer semantics",
        "language": "go",
