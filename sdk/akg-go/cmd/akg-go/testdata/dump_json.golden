    {
      "Type": "warning",
      "ID": "delete_edges_before_nodes",
      "Title": "Delete edges before nodes",
      "Body": "You must delete all inbound and outbound edges before deleting a node; the graph does not cascade-delete automatically.",
      "Meta": {
        "anchor": "deleting-nodes-and-edges",
