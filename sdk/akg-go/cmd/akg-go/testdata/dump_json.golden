    {
      "Type": "concept",
      "ID": "naming_rules",
      "Title": "Naming rules",
      "Body": "Type names, relation names, and tags must be lowercase [a-z0-9_] with no leading, trailing, or consecutive underscores.",
      "Meta": {
        "anchor": "naming-rules",
