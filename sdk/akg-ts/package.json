{
  "name": "akg-ts",
  "version": "0.3.0",
  "description": "TypeScript SDK for AKG knowledge graph files",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "akg-ts": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs/akg-ts-docs.akg",
    "docs/akg-ts-docs.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "generate:docs": "tsx scripts/generate-docs.ts",
    "generate:roundtrip": "tsx scripts/generate-roundtrip-fixture.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.20",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^1.6.0"
  }
}
