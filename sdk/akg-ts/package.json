{
  "name": "akg-ts",
  "version": "0.1.2",
  "description": "TypeScript SDK for AKG knowledge graph files",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "akg-ts": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs/akg-ts-docs.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "generate:docs": "tsx scripts/generate-docs.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
